# Dependencies
node_modules/

# Build outputs
dist/
build/

# Runtime / local data (never commit)
data/
uploads/
storage/
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3
# Exception: demo branch ships a seeded DB
!demo/securevault-demo.db

# Local config (use storage.json.example as template)
backend/config/storage.json

# Environment & secrets
.env
.env.*
!.env.example
!.env.*.example
.env.local
.env.*.local
.envrc

# Private keys / certificates (keys used by the app are in-browser; these are accidental leaks)
*.pem
*.p12
*.key
*_keys.json
keys.json
# Exception: demo branch ships a downloadable key file
!frontend/public/demo_admin_keys.json

# Docker local overrides (machine-specific paths, ports)
docker-compose.override.yml

# IDE (optional: commit .vscode/extensions.json for team recommendations)
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test / coverage
coverage/
.nyc_output/

# Caches & incremental TS
.cache/
.eslintcache
*.tsbuildinfo

# Vite / esbuild: transient compiled config beside vite.config.* (timestamp + hash in name)
**/vite.config.ts.timestamp-*.mjs
**/vite.config.js.timestamp-*.mjs
**/vite.config.mts.timestamp-*.mjs

# Playwright (setup tidak di-commit — sesuai kebijakan repo)
frontend/playwright.config.ts
frontend/e2e/
playwright-report/
test-results/
