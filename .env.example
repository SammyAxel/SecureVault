# SecureVault Environment Variables
# Copy this file to .env and adjust as needed.

# Application mode: development | production | test
NODE_ENV=development

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Server
PORT=3000
HOST=localhost

# Database (SQLite path)
DATABASE_URL=./data/securevault.db

# File storage root
STORAGE_PATH=./uploads

# CORS — comma-separated allowed origins (leave empty for development permissiveness)
# In production, set to your frontend origin(s):
# CORS_ORIGIN=https://vault.example.com
CORS_ORIGIN=

# Malware scanning API keys (optional)
# VIRUSTOTAL_API_KEY=your_key_here
# MALWAREBAZAAR_API_KEY=your_key_here

# Trash retention
TRASH_RETENTION_DAYS=30
TRASH_PURGE_INTERVAL_HOURS=24
