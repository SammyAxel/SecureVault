# SecureVault Environment Variables
# Copy this file to .env and adjust as needed.

# Application mode: development | production | test
NODE_ENV=development

# Logging level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Server
PORT=3000
HOST=localhost

# Database (SQLite path)
DATABASE_URL=./data/securevault.db

# File storage root
STORAGE_PATH=./uploads

# CORS — comma-separated allowed origins (leave empty for development permissiveness)
# In production, set to your frontend origin(s):
# CORS_ORIGIN=https://vault.example.com
CORS_ORIGIN=

# Public URL of the web app (https://...). When set, 2FA QR and device-link URLs use this
# instead of the request Host or X-Forwarded-* headers (safer behind untrusted proxies).
# PUBLIC_APP_URL=https://vault.example.com
PUBLIC_APP_URL=

# Malware scanning API keys (optional)
# VIRUSTOTAL_API_KEY=your_key_here
# MALWAREBAZAAR_API_KEY=your_key_here

# Trash retention
TRASH_RETENTION_DAYS=30
TRASH_PURGE_INTERVAL_HOURS=24

# Audit log retention (sqlite `audit_logs` table). 0 = keep forever. Typical: 90–365 for a bounded history.
# Uses the same purge interval as trash (TRASH_PURGE_INTERVAL_HOURS). Pino stdout logs are not affected.
AUDIT_LOG_RETENTION_DAYS=0

# --- Session security ---
# Browser sessions use HttpOnly cookie `sv_sid` plus CSRF cookie `sv_csrf` (X-CSRF-Token header on mutating /api calls).
# SESSION_COOKIE_SAMESITE: lax | strict | none (none requires HTTPS / Secure cookies)
SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_SECURE: auto (HTTPS or X-Forwarded-Proto) | true | false
SESSION_COOKIE_SECURE=auto
# Allow Authorization: Bearer for scripts/tests only (browser UI uses cookies).
LEGACY_BEARER_AUTH=false
# Bind session to login IP + User-Agent (false recommended unless you accept mobile re-auth).
SESSION_BIND_IP_UA=false
# When binding: treat same IPv4 /24 as the same network.
SESSION_BIND_IPV4_SUBNET=true
# Rotate opaque session token at most every N hours (0 = off). Shortens stolen-token window.
SESSION_ROTATE_HOURS=24
# Strict-Transport-Security (enable only when all users hit HTTPS end-to-end).
ENABLE_HSTS=false
HSTS_MAX_AGE_SECONDS=15552000
